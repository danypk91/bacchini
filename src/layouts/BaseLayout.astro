---
import { ViewTransitions } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import SEOHead from '@components/global/SEOHead.astro';
import Header from '@components/global/Header.astro';
import Footer from '@components/global/Footer.astro';
import QuoteSection from '@components/global/QuoteSection.astro';
import ScrollAnimations from '@components/global/ScrollAnimations.astro';
import Lightbox from '@components/global/Lightbox.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} ogImage={ogImage} />
    <slot name="head" />
    <ViewTransitions />
    <Analytics />
  </head>
  <body class="min-h-screen bg-bg-deep text-text-primary">
    <!-- Skip to content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-accent-cyan focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-bg-deep"
    >
      Skip to content
    </a>

    <Header transition:persist />

    <main id="main-content">
      <slot />
    </main>

    <QuoteSection />
    <Footer />
    <ScrollAnimations />
    <Lightbox />
  </body>
</html>
