---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactInfo from '@components/contact/ContactInfo.astro';
import PageHero from '@components/global/PageHero.astro';
---

<BaseLayout
  title="Contact"
  description="Contact Fabio Bacchini — KU Leuven and BIRA-IASB office addresses, email, and academic profiles."
>
  <PageHero
    title="Contact"
    subtitle="Get in touch for research collaborations, academic inquiries, or just to say hello."
    accentColor="orange"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
    </svg>
    <span class="text-xs font-medium tracking-wider uppercase">Get in Touch</span>
  </PageHero>

  <!-- Contact Info + Academic Profiles -->
  <ContactInfo />
</BaseLayout>
