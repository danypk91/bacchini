---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import AboutMe from '@components/research/AboutMe.astro';
import ResearchCard from '@components/research/ResearchCard.astro';
import TeamGrid from '@components/research/TeamGrid.astro';
import FormerMembers from '@components/research/FormerMembers.astro';
import SectionHeading from '@components/global/SectionHeading.astro';
import PageHero from '@components/global/PageHero.astro';

const allResearch = await getCollection('research');
const projects = allResearch.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Plasma Astrophysics Research"
  description="Research projects, team members, and academic profile of Fabio Bacchini — astrophysical plasma simulations, particle-in-cell methods, and high-performance computing."
  ogImage="/images/og/research.png"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fabiobacchini.com/" },
      { "@type": "ListItem", "position": 2, "name": "Research", "item": "https://fabiobacchini.com/research/" }
    ]
  })} />

  <PageHero
    title="Research"
    subtitle="Academic profile, current research projects, and team members."
    accentColor="cyan"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
    </svg>
    <span class="text-xs font-medium tracking-wider uppercase">Research & Team</span>
  </PageHero>

  <!-- About Me -->
  <AboutMe />

  <!-- Research Projects -->
  <section class="bg-bg-surface/50 py-16 md:py-24">
    <div class="mx-auto max-w-[1200px] px-6">
      <SectionHeading title="Current Research Projects" subtitle="Click to expand each research area" />

      <div class="space-y-4">
        {projects.map(async (project) => {
          const { Content } = await render(project);
          return (
            <ResearchCard
              title={project.data.title}
              icon={project.data.icon}
              color={project.data.color}
            >
              <Content />
            </ResearchCard>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Team Grid -->
  <TeamGrid />

  <!-- Former Members -->
  <FormerMembers />
</BaseLayout>
