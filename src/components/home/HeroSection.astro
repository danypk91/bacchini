---
import Button from '@components/global/Button.astro';
import HeroAnimation from '@components/interactive/HeroAnimation';
---

<section class="relative flex min-h-screen items-center overflow-hidden">
  <!-- Background simulation image -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-simulation.png"
      alt=""
      width="2460"
      height="1244"
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <!-- Dark overlay for text readability -->
  <div
    class="absolute inset-0"
    style="background: radial-gradient(ellipse at center, rgba(10,10,15,0.7) 0%, rgba(10,10,15,0.5) 50%, rgba(10,10,15,0.3) 100%);"
  ></div>

  <!-- Top/bottom vignette for blending with site -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to bottom, rgba(10,10,15,0.8) 0%, transparent 20%, transparent 80%, rgba(10,10,15,1) 100%);"
  ></div>

  <!-- Three.js particle animation -->
  <HeroAnimation client:only="react" />

  <div class="relative z-10 mx-auto flex max-w-[1200px] flex-col items-center px-6 py-32 text-center">
    <!-- Logo -->
    <img
      src="/images/logo-bacchini.png"
      alt=""
      width="120"
      height="53"
      class="mb-6 invert"
    />

    <h1 class="font-heading text-5xl font-bold leading-[1.05] text-text-primary md:text-7xl">
      Fabio Bacchini
    </h1>

    <div class="mt-4 space-y-1">
      <p class="text-lg text-text-secondary md:text-xl">
        KU Leuven · Centre for mathematical Plasma Astrophysics
      </p>
      <p class="text-lg text-text-secondary md:text-xl">
        Royal Belgian Institute for Space Aeronomy
      </p>
    </div>

    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button href="/research/" variant="primary" size="lg">
        Explore Research
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </Button>
      <Button href="/publications/" variant="ghost" size="lg">
        Publications
      </Button>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <a href="#about" class="flex flex-col items-center gap-2 text-text-muted transition-colors hover:text-accent-cyan">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <svg class="h-5 w-5 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
