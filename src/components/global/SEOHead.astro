---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description,
  ogImage = '/images/og/default.png',
  canonical,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = canonical ?? Astro.url.href;
const fullTitle = title === 'Home'
  ? 'Fabio Bacchini — Astrophysicist at KU Leuven'
  : `${title} — Fabio Bacchini`;
---

<!-- Primary Meta Tags -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Favicon -->
<meta name="theme-color" content="#0a0a0f" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

<!-- Preconnect & preload critical fonts -->
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="https://fonts.gstatic.com/s/spacegrotesk/v16/V8mDoQDjQSkFtoMM3T6r8E7mPbF4C_k3HqU.woff2" crossorigin />
<link rel="preload" as="font" type="font/woff2" href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfAZ9hiA.woff2" crossorigin />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Fabio Bacchini" />
<meta property="og:locale" content="en_US" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={`${siteUrl}${ogImage}`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

<!-- Schema.org Person -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Fabio Bacchini",
  "jobTitle": "Assistant Professor & Research Scientist",
  "url": siteUrl,
  "worksFor": [
    {
      "@type": "CollegeOrUniversity",
      "name": "KU Leuven",
      "department": "Centre for mathematical Plasma Astrophysics (CmPA)",
      "url": "https://wis.kuleuven.be/CmPA"
    },
    {
      "@type": "ResearchOrganization",
      "name": "Royal Belgian Institute for Space Aeronomy",
      "alternateName": "BIRA-IASB",
      "url": "https://www.aeronomie.be"
    }
  ],
  "email": ["fabio.bacchini@kuleuven.be", "fabio.bacchini@aeronomie.be"],
  "sameAs": [
    "https://scholar.google.com/citations?user=lVDg704AAAAJ",
    "https://orcid.org/0000-0002-7526-8154",
    "https://www.researchgate.net/profile/Fabio-Bacchini-2",
    "https://www.linkedin.com/in/fabio-bacchini-484766163/"
  ],
  "knowsAbout": [
    "plasma astrophysics",
    "particle-in-cell simulations",
    "high-performance computing",
    "magnetohydrodynamics",
    "magnetic reconnection"
  ]
})} />
