---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12">
  <div class="flex items-center gap-4">
    <h2 class="font-heading text-3xl font-bold text-text-primary md:text-4xl">
      {title}
    </h2>
    <div class="hidden h-px flex-1 bg-gradient-to-r from-accent-cyan/40 to-transparent md:block"></div>
  </div>
  {subtitle && (
    <p class="mt-3 text-text-secondary">{subtitle}</p>
  )}
</div>
