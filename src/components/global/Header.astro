---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/research/', label: 'Research' },
  { href: '/publications/', label: 'Publications' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current.startsWith(href);
}
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav
    aria-label="Main navigation"
    class="mx-auto flex max-w-[1200px] items-center justify-between px-6 py-4"
  >
    <!-- Logo / Name -->
    <a
      href="/"
      class="font-heading text-xl font-bold text-text-primary transition-colors hover:text-accent-cyan"
    >
      Fabio Bacchini
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'relative py-1 text-sm font-medium transition-colors',
              isActive(link.href, currentPath)
                ? 'text-accent-cyan'
                : 'text-text-secondary hover:text-text-primary',
            ]}
          >
            {link.label}
            <span class:list={[
              'absolute bottom-0 left-0 h-0.5 w-full bg-accent-cyan',
              !isActive(link.href, currentPath) && 'hidden',
            ]} />
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="relative z-50 flex h-10 w-10 items-center justify-center md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <div class="hamburger-icon">
        <span class="block h-0.5 w-6 bg-text-primary transition-all duration-300"></span>
        <span class="mt-1.5 block h-0.5 w-6 bg-text-primary transition-all duration-300"></span>
        <span class="mt-1.5 block h-0.5 w-6 bg-text-primary transition-all duration-300"></span>
      </div>
    </button>
  </nav>

</header>

<!-- Mobile Menu Overlay (outside header to avoid stacking context issues) -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[999] hidden"
>
  <!-- Solid background -->
  <div class="absolute inset-0 bg-bg-deep"></div>

  <!-- Subtle glow accent -->
  <div
    class="absolute left-1/2 top-1/3 h-[400px] w-[400px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-15 blur-3xl"
    style="background: radial-gradient(circle, rgba(0,212,255,0.4) 0%, transparent 70%);"
  ></div>

  <!-- Close button -->
  <button
    id="mobile-menu-close"
    class="absolute right-6 top-5 z-10 flex h-10 w-10 items-center justify-center"
    aria-label="Close menu"
  >
    <svg class="h-7 w-7 text-text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Centered menu content -->
  <div class="relative flex h-full flex-col items-center justify-center">
    <nav aria-label="Mobile navigation" class="flex flex-col items-center gap-1">
      {navLinks.map((link, i) => (
        <a
          href={link.href}
          class:list={[
            'mobile-nav-link group relative px-6 py-3 font-heading text-3xl font-bold tracking-tight transition-all duration-300',
            isActive(link.href, currentPath)
              ? 'text-accent-cyan'
              : 'text-text-muted hover:text-text-primary',
          ]}
           style={`transition-delay: ${50 + i * 70}ms;`}
        >
          {isActive(link.href, currentPath) && (
            <span class="absolute left-0 top-1/2 h-6 w-1 -translate-y-1/2 rounded-full bg-accent-cyan" />
          )}
          <span class="relative">
            {link.label}
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-accent-cyan transition-all duration-300 group-hover:w-full" />
          </span>
        </a>
      ))}
    </nav>

    <!-- Affiliations -->
    <div class="absolute bottom-12 flex flex-col items-center gap-1 text-center">
      <p class="text-xs text-text-muted">KU Leuven · BIRA-IASB</p>
    </div>
  </div>
</div>

<script>
  let isMenuOpen = false;

  // --- All clicks via event delegation — no DOM cloning, no flicker ---
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Hamburger button
    if (target.closest('#mobile-menu-btn')) {
      isMenuOpen ? closeMenu() : openMenu();
      return;
    }

    // Close button
    if (target.closest('#mobile-menu-close')) {
      closeMenu();
      return;
    }

    // Link inside mobile menu
    if (target.closest('#mobile-menu a')) {
      closeMenu();
      return;
    }

    // Click on overlay background (not on nav content or buttons)
    if (isMenuOpen && target.closest('#mobile-menu') && !target.closest('nav') && !target.closest('button')) {
      closeMenu();
      return;
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });

  // --- Active link update ---
  function updateActiveLinks() {
    const path = window.location.pathname;

    // Desktop links
    document.querySelectorAll('#main-header ul a').forEach((a) => {
      const href = a.getAttribute('href') || '';
      const active = href === '/' ? path === '/' : path.startsWith(href);
      const underline = a.querySelector('span');

      if (active) {
        a.classList.remove('text-text-secondary', 'hover:text-text-primary');
        a.classList.add('text-accent-cyan');
        if (underline) underline.classList.remove('hidden');
      } else {
        a.classList.remove('text-accent-cyan');
        a.classList.add('text-text-secondary', 'hover:text-text-primary');
        if (underline) underline.classList.add('hidden');
      }
    });

    // Mobile links
    document.querySelectorAll('#mobile-menu .mobile-nav-link').forEach((a) => {
      const href = a.getAttribute('href') || '';
      const active = href === '/' ? path === '/' : path.startsWith(href);

      if (active) {
        a.classList.remove('text-text-muted', 'hover:text-text-primary');
        a.classList.add('text-accent-cyan');
      } else {
        a.classList.remove('text-accent-cyan');
        a.classList.add('text-text-muted', 'hover:text-text-primary');
      }
    });
  }

  // --- Scroll behavior ---
  function handleScroll() {
    const header = document.getElementById('main-header');
    if (!header) return;
    const isHome = window.location.pathname === '/';
    if (window.scrollY > 50) {
      header.classList.add('bg-bg-deep/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-bg-deep/50');
    } else if (isHome) {
      header.classList.remove('bg-bg-deep/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-bg-deep/50');
    }
  }

  function updateHeaderBg() {
    const header = document.getElementById('main-header');
    if (!header) return;
    if (window.location.pathname !== '/') {
      header.classList.add('bg-bg-deep/95', 'backdrop-blur-md');
    } else {
      header.classList.remove('bg-bg-deep/95', 'backdrop-blur-md');
      handleScroll();
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });

  // --- Menu open/close ---
  function closeMenu() {
    if (!isMenuOpen) return;
    isMenuOpen = false;

    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('mobile-menu-btn');
    const lines = btn?.querySelectorAll('.hamburger-icon span');

    btn?.setAttribute('aria-expanded', 'false');
    menu?.classList.add('hidden');

    if (lines && lines.length === 3) {
      lines[0].classList.remove('rotate-45', 'translate-y-[8px]');
      lines[1].classList.remove('opacity-0');
      lines[2].classList.remove('-rotate-45', '-translate-y-[8px]');
    }

    document.body.style.overflow = '';
  }

  function openMenu() {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('mobile-menu-btn');
    const lines = btn?.querySelectorAll('.hamburger-icon span');
    const links = menu?.querySelectorAll('.mobile-nav-link');
    if (!menu) return;

    isMenuOpen = true;
    btn?.setAttribute('aria-expanded', 'true');

    // Reset links before showing
    links?.forEach((link) => {
      (link as HTMLElement).style.opacity = '0';
      (link as HTMLElement).style.transform = 'translateY(12px)';
    });

    // Show menu instantly (no opacity fade)
    menu.classList.remove('hidden');

    // Stagger links entrance
    requestAnimationFrame(() => {
      links?.forEach((link, i) => {
        setTimeout(() => {
          (link as HTMLElement).style.opacity = '1';
          (link as HTMLElement).style.transform = 'translateY(0)';
        }, 50 + i * 70);
      });
    });

    if (lines && lines.length === 3) {
      lines[0].classList.add('rotate-45', 'translate-y-[8px]');
      lines[1].classList.add('opacity-0');
      lines[2].classList.add('-rotate-45', '-translate-y-[8px]');
    }

    document.body.style.overflow = 'hidden';
  }

  // --- Init ---
  updateActiveLinks();
  updateHeaderBg();

  // Update header bg BEFORE the DOM swap to avoid flicker
  document.addEventListener('astro:before-swap', (e: any) => {
    const toUrl = new URL(e.to, location.origin);
    const header = document.getElementById('main-header');
    if (!header) return;

    if (toUrl.pathname !== '/') {
      header.classList.add('bg-bg-deep/95', 'backdrop-blur-md');
    } else {
      header.classList.remove('bg-bg-deep/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-bg-deep/50');
    }
  });

  document.addEventListener('astro:after-swap', () => {
    isMenuOpen = false;
    document.body.style.overflow = '';
    updateActiveLinks();
    updateHeaderBg();
  });
</script>
