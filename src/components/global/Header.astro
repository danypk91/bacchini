---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/research/', label: 'Research' },
  { href: '/publications/', label: 'Publications' },
  { href: '/contact/', label: 'Contact' },
];

function isActive(href: string, current: string): boolean {
  if (href === '/') return current === '/';
  return current.startsWith(href);
}
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav
    class="mx-auto flex max-w-[1200px] items-center justify-between px-6 py-4"
  >
    <!-- Logo / Name -->
    <a
      href="/"
      class="font-heading text-xl font-bold text-text-primary transition-colors hover:text-accent-cyan"
    >
      Fabio Bacchini
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'relative py-1 text-sm font-medium transition-colors',
              isActive(link.href, currentPath)
                ? 'text-accent-cyan'
                : 'text-text-secondary hover:text-text-primary',
            ]}
          >
            {link.label}
            {isActive(link.href, currentPath) && (
              <span class="absolute bottom-0 left-0 h-0.5 w-full bg-accent-cyan" />
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="relative z-50 flex h-10 w-10 items-center justify-center md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <div class="hamburger-icon">
        <span class="block h-0.5 w-6 bg-text-primary transition-all duration-300"></span>
        <span class="mt-1.5 block h-0.5 w-6 bg-text-primary transition-all duration-300"></span>
        <span class="mt-1.5 block h-0.5 w-6 bg-text-primary transition-all duration-300"></span>
      </div>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 hidden opacity-0 transition-opacity duration-300"
  >
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-bg-deep/90 backdrop-blur-sm"></div>

    <!-- Menu Panel -->
    <div class="absolute right-0 top-0 flex h-full w-72 translate-x-full flex-col bg-bg-surface/80 backdrop-blur-xl border-l border-white/5 transition-transform duration-300">
      <div class="flex flex-col gap-2 px-8 pt-24">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'mobile-nav-link py-3 text-lg font-medium transition-colors border-b border-bg-elevated',
              isActive(link.href, currentPath)
                ? 'text-accent-cyan'
                : 'text-text-secondary hover:text-text-primary',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    const header = document.getElementById('main-header');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerLines = menuBtn?.querySelectorAll('.hamburger-icon span');

    if (!header || !menuBtn || !mobileMenu) return;

    let isMenuOpen = false;

    // Scroll behavior — solidify header
    function handleScroll() {
      if (!header) return;
      const isHome = window.location.pathname === '/';

      if (window.scrollY > 50) {
        header.classList.add('bg-bg-deep/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-bg-deep/50');
      } else if (isHome) {
        header.classList.remove('bg-bg-deep/95', 'backdrop-blur-md', 'shadow-lg', 'shadow-bg-deep/50');
      }
    }

    // Set initial state for non-home pages
    if (window.location.pathname !== '/') {
      header.classList.add('bg-bg-deep/95', 'backdrop-blur-md');
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // Mobile menu toggle
    function toggleMenu() {
      isMenuOpen = !isMenuOpen;
      menuBtn!.setAttribute('aria-expanded', String(isMenuOpen));

      const menuPanel = mobileMenu!.querySelector('.absolute.right-0') as HTMLElement;

      if (isMenuOpen) {
        mobileMenu!.classList.remove('hidden');
        // Trigger reflow for transition
        requestAnimationFrame(() => {
          mobileMenu!.classList.remove('opacity-0');
          mobileMenu!.classList.add('opacity-100');
          menuPanel?.classList.remove('translate-x-full');
          menuPanel?.classList.add('translate-x-0');
        });

        // Animate hamburger to X
        if (hamburgerLines && hamburgerLines.length === 3) {
          hamburgerLines[0].classList.add('rotate-45', 'translate-y-[8px]');
          hamburgerLines[1].classList.add('opacity-0');
          hamburgerLines[2].classList.add('-rotate-45', '-translate-y-[8px]');
        }

        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu!.classList.remove('opacity-100');
        mobileMenu!.classList.add('opacity-0');
        menuPanel?.classList.remove('translate-x-0');
        menuPanel?.classList.add('translate-x-full');

        if (hamburgerLines && hamburgerLines.length === 3) {
          hamburgerLines[0].classList.remove('rotate-45', 'translate-y-[8px]');
          hamburgerLines[1].classList.remove('opacity-0');
          hamburgerLines[2].classList.remove('-rotate-45', '-translate-y-[8px]');
        }

        document.body.style.overflow = '';

        setTimeout(() => {
          mobileMenu!.classList.add('hidden');
        }, 300);
      }
    }

    menuBtn.addEventListener('click', toggleMenu);

    // Close on backdrop click
    mobileMenu.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).classList.contains('backdrop-blur-sm') ||
          (e.target as HTMLElement).tagName === 'A') {
        if (isMenuOpen) toggleMenu();
      }
    });

    // Close on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) toggleMenu();
    });
  }

  // Run on initial load and on View Transitions navigation
  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
