---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
}

const { href, variant = 'primary', size = 'md', external = false } = Astro.props;

const Tag = href ? 'a' : 'button';

const variantClasses: Record<string, string> = {
  primary:
    'bg-accent-cyan text-bg-deep font-semibold hover:bg-accent-cyan/90 shadow-lg shadow-accent-cyan/20',
  secondary:
    'bg-bg-elevated text-text-primary font-medium hover:bg-bg-elevated/80 border border-bg-elevated',
  ghost:
    'text-text-primary font-medium hover:text-white bg-white/10 backdrop-blur-sm border border-white/25 hover:bg-white/20 hover:border-white/40',
};

const sizeClasses: Record<string, string> = {
  sm: 'px-4 py-2 text-sm rounded-lg',
  md: 'px-6 py-2.5 text-sm rounded-xl',
  lg: 'px-8 py-3 text-base rounded-xl',
};

const externalAttrs = external
  ? { target: '_blank', rel: 'noopener noreferrer' }
  : {};
---

<Tag
  href={href}
  class:list={[
    'inline-flex items-center gap-2 transition-all duration-200',
    variantClasses[variant],
    sizeClasses[size],
  ]}
  {...externalAttrs}
>
  <slot />
</Tag>
