---
interface Props {
  institution: string;
  department: string;
  address: string[];
  email: string;
  website: string;
  mapsUrl: string;
  accentColor?: string;
}

const { institution, department, address, email, website, mapsUrl, accentColor = 'accent-cyan' } = Astro.props;
---

<div class="group rounded-2xl border border-bg-elevated bg-bg-surface p-6 transition-all duration-300 hover:border-accent-cyan/30 hover:shadow-lg hover:shadow-accent-cyan/5 md:p-8">
  <!-- Institution icon -->
  <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-accent-cyan/10 text-accent-cyan">
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" />
    </svg>
  </div>

  <!-- Institution name -->
  <h3 class="font-heading text-xl font-bold text-text-primary">{institution}</h3>
  <p class="mt-1 text-sm text-accent-cyan">{department}</p>

  <!-- Address -->
  <div class="mt-5 space-y-0.5">
    {address.map((line) => (
      <p class="text-sm text-text-secondary">{line}</p>
    ))}
  </div>

  <!-- Email -->
  <a
    href={`mailto:${email}`}
    class="mt-4 inline-flex items-center gap-2 text-sm text-text-secondary transition-colors hover:text-accent-cyan"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
    </svg>
    {email}
  </a>

  <!-- Links row -->
  <div class="mt-5 flex items-center gap-4">
    <a
      href={website}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-xs font-medium text-text-muted transition-colors hover:text-accent-cyan"
    >
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
      </svg>
      Website
    </a>
    <a
      href={mapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-xs font-medium text-text-muted transition-colors hover:text-accent-cyan"
    >
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
      </svg>
      View on Maps
    </a>
  </div>
</div>
