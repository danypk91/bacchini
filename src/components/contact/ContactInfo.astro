---
import SectionHeading from '@components/global/SectionHeading.astro';
import LocationCard from './LocationCard.astro';
---

<section class="py-16 md:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <SectionHeading title="Get in Touch" subtitle="Reach out at either of my institutional offices" />

    <!-- Location Cards Grid -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <LocationCard
        institution="KU Leuven"
        department="Centre for mathematical Plasma Astrophysics (CmPA)"
        address={["Department of Mathematics", "Celestijnenlaan 200B 04.34", "3001 Leuven, Belgium"]}
        email="fabio.bacchini@kuleuven.be"
        website="https://wis.kuleuven.be/CmPA"
        mapsUrl="https://maps.google.com/?q=Celestijnenlaan+200B,+3001+Leuven,+Belgium"
      />
      <LocationCard
        institution="BIRA-IASB"
        department="Royal Belgian Institute for Space Aeronomy"
        address={["Ringlaan 3 Avenue Circulaire", "1180 Brussels, Belgium"]}
        email="fabio.bacchini@aeronomie.be"
        website="https://www.aeronomie.be"
        mapsUrl="https://maps.google.com/?q=Ringlaan+3,+1180+Brussels,+Belgium"
      />
    </div>
  </div>
</section>

<!-- Academic Profiles -->
<section class="bg-bg-surface/50 py-16 md:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <SectionHeading title="Academic Profiles" subtitle="Find me on these platforms" />

    <div class="flex flex-wrap justify-center gap-4 md:gap-6">
      <!-- Google Scholar -->
      <a
        href="https://scholar.google.com/citations?user=lVDg704AAAAJ"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 rounded-xl border border-bg-elevated bg-bg-surface px-5 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-accent-cyan/30 hover:shadow-lg hover:shadow-accent-cyan/5"
      >
        <svg class="h-6 w-6 text-text-muted transition-colors group-hover:text-accent-cyan" viewBox="0 0 24 24" fill="currentColor">
          <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 100 14 7 7 0 000-14z" />
        </svg>
        <span class="text-sm font-medium text-text-secondary transition-colors group-hover:text-text-primary">Google Scholar</span>
      </a>

      <!-- ORCID -->
      <a
        href="https://orcid.org/0000-0002-7526-8154"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 rounded-xl border border-bg-elevated bg-bg-surface px-5 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-accent-cyan/30 hover:shadow-lg hover:shadow-accent-cyan/5"
      >
        <svg class="h-6 w-6 text-text-muted transition-colors group-hover:text-[#A6CE39]" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-1.847-1.181-3.722-3.953-3.722h-2.366z" />
        </svg>
        <span class="text-sm font-medium text-text-secondary transition-colors group-hover:text-text-primary">ORCID</span>
      </a>

      <!-- ResearchGate -->
      <a
        href="https://www.researchgate.net/profile/Fabio-Bacchini"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 rounded-xl border border-bg-elevated bg-bg-surface px-5 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-accent-cyan/30 hover:shadow-lg hover:shadow-accent-cyan/5"
      >
        <svg class="h-6 w-6 text-text-muted transition-colors group-hover:text-[#00CCBB]" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.586 0c-1.893.009-3.589 1.16-4.323 2.99-.09.22-.175.457-.244.7-.597-1.753-2.087-2.95-3.857-3.15a4.714 4.714 0 00-.524-.03C8.073.51 5.97 2.68 5.97 5.348c0 .266.02.53.062.793.092.599.263 1.16.492 1.672.684 1.527 1.926 2.594 3.398 2.939a4.603 4.603 0 002.024.074c-.053.263-.129.52-.228.77-.478 1.207-1.425 2.156-2.594 2.593-.272.102-.556.178-.848.224a5.56 5.56 0 01-1.1.06c-.682-.044-1.342-.23-1.94-.55-.7-.372-1.31-.912-1.774-1.566a.375.375 0 00-.624.418c.52.735 1.21 1.343 2.001 1.77.7.371 1.468.59 2.26.641a6.317 6.317 0 001.25-.068c.332-.052.656-.14.968-.264 1.32-.494 2.387-1.562 2.926-2.93.11-.28.2-.572.265-.872a4.558 4.558 0 003.108-1.545c.676-.753 1.102-1.714 1.19-2.747.04-.48.004-.965-.107-1.434-.27-1.143-.96-2.126-1.915-2.766A4.61 4.61 0 0016.78.54c-.254-.023-.51-.033-.768-.034H19.586z" />
        </svg>
        <span class="text-sm font-medium text-text-secondary transition-colors group-hover:text-text-primary">ResearchGate</span>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/fbacchini"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 rounded-xl border border-bg-elevated bg-bg-surface px-5 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-accent-cyan/30 hover:shadow-lg hover:shadow-accent-cyan/5"
      >
        <svg class="h-6 w-6 text-text-muted transition-colors group-hover:text-text-primary" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
        </svg>
        <span class="text-sm font-medium text-text-secondary transition-colors group-hover:text-text-primary">GitHub</span>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/fabio-bacchini-484766163/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 rounded-xl border border-bg-elevated bg-bg-surface px-5 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-accent-cyan/30 hover:shadow-lg hover:shadow-accent-cyan/5"
      >
        <svg class="h-6 w-6 text-text-muted transition-colors group-hover:text-[#0A66C2]" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        <span class="text-sm font-medium text-text-secondary transition-colors group-hover:text-text-primary">LinkedIn</span>
      </a>
    </div>
  </div>
</section>
