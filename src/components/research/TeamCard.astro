---
interface Props {
  name: string;
  title?: string;
  role: string;
  photo?: string;
}

const { name, title: honorific, role, photo } = Astro.props;
const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();
---

<div class="group flex flex-col items-center text-center">
  <div class="relative mb-4 overflow-hidden rounded-xl border-2 border-bg-elevated transition-all duration-300 group-hover:border-accent-cyan/50 group-hover:shadow-lg group-hover:shadow-accent-cyan/10">
    {photo ? (
      <img
        src={photo}
        alt={name}
        class="aspect-[3/4] w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class="flex aspect-[3/4] w-full items-center justify-center bg-bg-elevated text-xl font-semibold text-text-muted">
        {initials}
      </div>
    )}
  </div>
  <h4 class="font-heading text-sm font-semibold text-text-primary">
    {honorific && <span class="text-text-muted">{honorific} </span>}
    {name}
  </h4>
  <p class="mt-1 text-xs text-text-muted">{role}</p>
</div>
